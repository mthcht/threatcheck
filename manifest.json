{
  "manifest_version": 3,
  "name": "ThreatCheck",
  "version": "1.0.0",
  "description": "Select any IOC on any web page to look it up across 29 threat intel platforms. Bulk extraction. API enrichment.",
  "author": "mthcht",
  "homepage_url": "https://github.com/mthcht/threatcheck",
  "permissions": ["storage","contextMenus"],
  "host_permissions": [
    "https://api.recordedfuture.com/*",
    "https://api.dnsdumpster.com/*",
    "https://app.validin.com/*",
    "https://api.spur.us/*",
    "https://urlscan.io/*",
    "https://www.virustotal.com/*",
    "https://api.abuseipdb.com/*",
    "https://leakcheck.io/*"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "background": {"service_worker": "background.js"},
  "content_scripts": [{"matches":["<all_urls>"],"js":["content.js"],"css":["styles.css"],"run_at":"document_idle"}],
  "options_ui": {"page":"options.html","open_in_tab":true},
  "action": {"default_icon":{"16":"icons/icon16.png","48":"icons/icon48.png"},"default_title":"ThreatCheck","default_popup":"popup.html"},
  "icons": {"16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png"},
  "content_security_policy": {"extension_pages":"script-src 'self'; object-src 'self'"},
  "commands": {
    "lookup-selection": {
      "suggested_key": {"default": "Alt+T", "mac": "Alt+T"},
      "description": "Look up selected text on ThreatCheck"
    }
  }
}
